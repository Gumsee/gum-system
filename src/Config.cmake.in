@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/@CMAKE_PROJECT_NAME@Targets.cmake")

check_required_components(@CMAKE_PROJECT_NAME@)

set(GUMSYSTEM_INCLUDE_DIRS   "@CMAKE_INSTALL_FULL_INCLUDEDIR@/@CMAKE_PROJECT_NAME@" )
find_library(GUMSYSTEM_LIBRARIES NAMES @CMAKE_PROJECT_NAME@
    PATHS
    /usr/lib
    /usr/local/lib
)

set(GUMSYSTEM_FOUND TRUE)
if(NOT GUMSYSTEM_LIBRARIES)
    set(GUMSYSTEM_FOUND FALSE)
endif()
